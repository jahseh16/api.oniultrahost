# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ─── MongoDB ──────────────────────────────────────────────────────────────────
# Local: mongodb://127.0.0.1:27017/oniultrahost
# Atlas: mongodb+srv://user:pass@cluster.mongodb.net/oniultrahost
MONGO_URI=mongodb://127.0.0.1:27017/oniultrahost

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Genera uno seguro con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CAMBIA_ESTO_POR_UN_STRING_ALEATORIO_MUY_LARGO
JWT_EXPIRES_IN=7d

# JWT para tokens de refresco (opcional fase 2)
JWT_REFRESH_SECRET=CAMBIA_ESTO_TAMBIEN
JWT_REFRESH_EXPIRES_IN=30d

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Dominios separados por coma
ALLOWED_ORIGINS=https://oniultrahost.lat,https://www.oniultrahost.lat,http://localhost:5173
